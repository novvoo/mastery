# Model Provider: local | openai | zhipu | deepseek | openrouter
MODEL_PROVIDER=openai

# Local model config (node-llama-cpp)
LOCAL_MODEL_PATH=./models/qwen3-1.7b-q8_0.gguf
LOCAL_CONTEXT_SIZE=8192

# OpenAI compatible API config
# Supports: OpenAI, Azure, and any OpenAI-compatible endpoint
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
TEMPERATURE=0.7

# Proxy settings (optional)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080

# Zhipu AI (智谱清言) - https://open.bigmodel.cn
# ZHIPU_API_KEY=xxx.xxx
# MODEL_PROVIDER=zhipu
# ZHIPU_MODEL=glm-4

# DeepSeek - https://platform.deepseek.com
# DEEPSEEK_API_KEY=sk-xxx
# MODEL_PROVIDER=deepseek
# DEEPSEEK_MODEL=deepseek-chat

# OpenRouter - https://openrouter.ai
# OPENROUTER_API_KEY=sk-or-xxx
# MODEL_PROVIDER=openrouter
# OPENROUTER_MODEL=openai/gpt-4
# OPENROUTER_REFERER=https://your-site.com

# Example: ai.inproute.com (nested JSON response format)
# OPENAI_API_KEY=null
# OPENAI_BASE_URL=https://ai.inproute.com/v1
# OPENAI_MODEL=qwen3.5-plus

# Agent config
MAX_ITERATIONS=30
MAX_TOKENS=4096
WORKING_DIRECTORY=./workspace

# Debug
DEBUG=false
LOG_DIR=./logs

# MCP (Model Context Protocol) Configuration
# MCP allows connecting to external tools and data sources
# See: https://modelcontextprotocol.io

# Example: Connect to filesystem MCP server
# MCP_FILESYSTEM_ENABLED=true
# MCP_FILESYSTEM_COMMAND=npx
# MCP_FILESYSTEM_ARGS=-y,@modelcontextprotocol/server-filesystem,/home/user

# Example: Connect to GitHub MCP server
# MCP_GITHUB_ENABLED=true
# MCP_GITHUB_COMMAND=npx
# MCP_GITHUB_ARGS=-y,@modelcontextprotocol/server-github
# MCP_GITHUB_TOKEN=ghp_xxx

# Example: Connect to SQLite MCP server
# MCP_SQLITE_ENABLED=true
# MCP_SQLITE_COMMAND=npx
# MCP_SQLITE_ARGS=-y,@modelcontextprotocol/server-sqlite,/path/to/database.db

# Example: Connect to custom MCP server (stdio transport)
# MCP_CUSTOM_ENABLED=true
# MCP_CUSTOM_COMMAND=python
# MCP_CUSTOM_ARGS=/path/to/server.py
# MCP_CUSTOM_ENV={"API_KEY": "xxx"}
