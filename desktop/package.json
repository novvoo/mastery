{
  "name": "ai-agent-desktop",
  "version": "1.0.21",
  "type": "module",
  "description": "AI Agent Desktop Application (Electron) - Part of ai-engineering-mastery-agent",
  "main": "main.js",
  "author": "AI Agent Team",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dev:vite": "vite --config vite.config.js",
    "build": "npx electron-builder",
    "build:win": "npx electron-builder --win",
    "build:mac": "npx electron-builder --mac",
    "build:linux": "npx electron-builder --linux",
    "build:all": "npx electron-builder --win --mac --linux",
    "pack": "npx electron-builder --dir",
    "dist": "npx electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.0.10"
  }
}
