{
  "name": "ai-engineering-mastery-agent",
  "version": "1.0.13",
  "description": "AI Engineering Mastery Agent - A standalone ReAct agent with 12 professional coding skills, sandbox execution, graph planning, 3-layer memory, and MCP protocol support",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "agent": "src/index.js"
  },
  "scripts": {
    "start": "bun src/index.js",
    "start:new": "USE_NEW_ARCH=true bun src/new-index.js",
    "start:debug": "DEBUG=true AGENT_TRACE=true bun src/index.js",
    "start:inspect": "bun --inspect src/index.js",
    "dev": "bun --watch src/index.js",
    "dev:debug": "DEBUG=true AGENT_TRACE=true bun --watch src/index.js",
    "dev:inspect": "bun --inspect --watch src/index.js",
    "test": "bun test-integration.mjs",
    "test:debug": "bun --inspect-brk test-integration.mjs",
    "test:integration": "bun test-integration.mjs",
    "test:watch": "bun --watch test-integration.mjs",
    "test:runtime": "bun test tests/runtime/integration.test.js",
    "test:adapters": "bun test tests/adapters/cli.test.js",
    "test:all": "bun test tests/",
    "test:e2e": "bun test tests/e2e/runtime-e2e.test.js",
    "test:e2e:watch": "bun --watch tests/e2e/runtime-e2e.test.js",
    "lint": "eslint src test-integration.mjs",
    "package:release": "bun scripts/prepare-release-package.mjs",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "examples": "bun examples/runtime-usage.js",
    "examples:runtime": "bun examples/runtime-usage.js",
    "examples:plugins": "bun examples/plugin-system.js",
    "examples:desktop": "bun examples/desktop-integration.js",
    "examples:performance": "bun examples/performance-tests.js",
    "examples:all": "bun examples/runtime-usage.js && bun examples/plugin-system.js && bun examples/desktop-integration.js",
    "desktop:dev": "cd desktop && npm run dev",
    "desktop:start": "cd desktop && npm run start",
    "desktop:build": "cd desktop && npm run build",
    "desktop:build:win": "cd desktop && npm run build:win",
    "desktop:build:mac": "cd desktop && npm run build:mac",
    "desktop:build:linux": "cd desktop && npm run build:linux",
    "desktop:build:all": "cd desktop && npm run build:all",
    "desktop:pack": "cd desktop && npm run pack",
    "desktop:dist": "cd desktop && npm run dist",
    "build:desktop": "bun run desktop:build",
    "build:all": "bun run desktop:build:all",
    "release:desktop": "bun run desktop:dist && bun run package:release"
  },
  "keywords": [
    "ai-agent",
    "coding-assistant",
    "react-agent",
    "llm",
    "mcp",
    "sandbox",
    "graph-planner",
    "memory-system",
    "eval-framework"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "dependencies": {
    "@huggingface/tokenizers": "^0.1.3",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "dotenv": "^17.0.0",
    "glob": "^11.0.0",
    "https-proxy-agent": "^9.0.0",
    "inquirer": "^13.4.3",
    "mammoth": "^1.12.0",
    "onnxruntime-node": "^1.26.0",
    "openai": "^4.73.0",
    "ora": "^8.2.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "eslint": "^8.57.1"
  }
}
