{
  "name": "ai-engineering-mastery-agent",
  "version": "1.0.0",
  "description": "AI Engineering Mastery Agent - A standalone ReAct agent with 12 professional coding skills, sandbox execution, graph planning, 3-layer memory, and MCP protocol support",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "agent": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "start:debug": "DEBUG=true AGENT_TRACE=true node src/index.js",
    "start:inspect": "node --inspect src/index.js",
    "dev": "node --watch src/index.js",
    "dev:debug": "DEBUG=true AGENT_TRACE=true node --watch src/index.js",
    "dev:inspect": "node --watch --inspect src/index.js",
    "test": "node test-integration.mjs",
    "test:debug": "node --inspect-brk test-integration.mjs",
    "test:integration": "node test-integration.mjs",
    "test:watch": "node --watch test-integration.mjs",
    "lint": "eslint src test-integration.mjs",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai-agent",
    "coding-assistant",
    "react-agent",
    "llm",
    "mcp",
    "sandbox",
    "graph-planner",
    "memory-system",
    "eval-framework"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "dotenv": "^17.0.0",
    "glob": "^11.0.0",
    "https-proxy-agent": "^9.0.0",
    "inquirer": "^13.4.3",
    "node-pty": "^1.1.0",
    "openai": "^4.73.0",
    "ora": "^8.2.0"
  },
  "optionalDependencies": {
    "node-llama-cpp": "^3.14.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1"
  }
}
